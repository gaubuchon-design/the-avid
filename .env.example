# =============================================================================
# The Avid - Environment Variables
# =============================================================================
# Copy this file to .env and adjust values for your environment.
# Docker Compose will automatically load .env from the project root.
#
# For API-specific variables, see also: apps/api/.env.example
# =============================================================================

# --- General ------------------------------------------------------------------
NODE_ENV=development

# --- PostgreSQL ---------------------------------------------------------------
POSTGRES_USER=avid
POSTGRES_PASSWORD=avid_dev_password
POSTGRES_DB=avid_db
POSTGRES_PORT=5432

# --- Redis --------------------------------------------------------------------
REDIS_PORT=6379

# --- MinIO (S3-compatible storage) --------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# --- S3 Buckets ---------------------------------------------------------------
S3_BUCKET_MEDIA=avid-media-assets
S3_BUCKET_PROXIES=avid-media-proxies
S3_BUCKET_EXPORTS=avid-exports

# --- API Server ---------------------------------------------------------------
API_PORT=4000
JWT_SECRET=dev-secret-change-in-production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
LOG_LEVEL=debug
AWS_REGION=us-east-1

# --- Turbo Remote Cache (optional) --------------------------------------------
# TURBO_TOKEN=your-turbo-token
# TURBO_TEAM=your-turbo-team

# --- AI / OpenAI (required for AI features) -----------------------------------
# OPENAI_API_KEY=sk-your-openai-api-key

# --- Stripe (required for billing) --------------------------------------------
# STRIPE_SECRET_KEY=sk_test_your-stripe-key
# STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
