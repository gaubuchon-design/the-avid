# Server
NODE_ENV=development
PORT=4000
API_BASE_URL=http://localhost:4000

# Database
DATABASE_URL="postgresql://avid:avid_dev_password@localhost:5432/avid_db"

# Redis
REDIS_URL="redis://localhost:6379"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# AWS S3 (Media Storage)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
S3_BUCKET_MEDIA=avid-media-assets
S3_BUCKET_PROXIES=avid-media-proxies
S3_BUCKET_EXPORTS=avid-exports
CLOUDFRONT_DOMAIN=your-cloudfront-domain.cloudfront.net

# AI / OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_TRANSCRIPTION_MODEL=whisper-1
OPENAI_ASSEMBLY_MODEL=gpt-4o

# Stripe (Billing / Tokens)
STRIPE_SECRET_KEY=sk_test_your-stripe-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
STRIPE_PRICE_PRO_MONTHLY=price_pro_monthly_id
STRIPE_PRICE_ENTERPRISE=price_enterprise_id

# Email (SendGrid or similar)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your-sendgrid-api-key
FROM_EMAIL=noreply@avid.app
FROM_NAME=The Avid

# OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
APPLE_CLIENT_ID=com.avid.app
APPLE_TEAM_ID=your-apple-team-id
APPLE_KEY_ID=your-apple-key-id
APPLE_PRIVATE_KEY_PATH=./certs/apple-auth.p8

# Social Publishing
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret
INSTAGRAM_APP_ID=your-instagram-app-id
INSTAGRAM_APP_SECRET=your-instagram-app-secret
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# WebSocket
WS_HEARTBEAT_INTERVAL=30000
WS_MAX_PAYLOAD=52428800

# FFmpeg
FFMPEG_PATH=/usr/local/bin/ffmpeg
FFPROBE_PATH=/usr/local/bin/ffprobe

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000

# Logging
LOG_LEVEL=debug
LOG_FILE=logs/app.log

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,avid://app
