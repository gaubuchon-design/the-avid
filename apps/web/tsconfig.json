{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "paths": {
      "@mcua/core": [
        "../../packages/core/src"
      ],
      "@mcua/core/*": [
        "../../packages/core/src/*"
      ]
    }
  },
  "include": [
    "src"
  ]
}
