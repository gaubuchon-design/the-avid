{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "baseUrl": ".",
    "paths": {
      "@mcua/core": [
        "../../packages/core/src"
      ],
      "@mcua/core/*": [
        "../../packages/core/src/*"
      ],
      "@mcua/ui": [
        "../../packages/ui/src"
      ],
      "@mcua/ui/*": [
        "../../packages/ui/src/*"
      ],
      "@mcua/editor": [
        "../../packages/editor/src"
      ],
      "@mcua/editor/*": [
        "../../packages/editor/src/*"
      ]
    }
  },
  "include": [
    "src"
  ]
}
