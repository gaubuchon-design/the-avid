{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": false,
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@mcua/core": ["../core/src"],
      "@mcua/core/*": ["../core/src/*"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../core" }
  ]
}
