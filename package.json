{
  "name": "media-composer-unified-application",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.11.0",
  "workspaces": [
    "apps/*",
    "packages/*",
    "libs/*",
    "services/*"
  ],
  "scripts": {
    "preinstall": "node -e \"if (process.env.npm_execpath.indexOf('pnpm') !== -1) { console.error('Use npm, not pnpm'); process.exit(1); }\"",
    "postinstall": "turbo run build --filter=@mcua/contracts --filter=@mcua/core --filter=@mcua/media-backend",
    "dev": "turbo run dev",
    "dev:web": "turbo run dev --filter=@mcua/web",
    "dev:desktop": "turbo run dev --filter=@mcua/desktop",
    "dev:mobile": "turbo run dev --filter=@mcua/mobile",
    "dev:api": "turbo run dev --filter=@mcua/api",
    "dev:services": "turbo run dev --filter='./services/*'",
    "build": "turbo run build",
    "build:web": "turbo run build --filter=@mcua/web",
    "build:desktop": "turbo run build --filter=@mcua/desktop",
    "build:mobile": "turbo run build --filter=@mcua/mobile",
    "version:desktop": "node apps/desktop/scripts/sync-version.js",
    "version:desktop:auto": "node apps/desktop/scripts/sync-version.js --auto",
    "dist:desktop": "npm run dist --workspace=@mcua/desktop --",
    "dist:desktop:refresh": "npm run dist:refresh --workspace=@mcua/desktop --",
    "dist:desktop:refresh:mac": "npm run dist:refresh:mac --workspace=@mcua/desktop --",
    "dist:desktop:refresh:win": "npm run dist:refresh:win --workspace=@mcua/desktop --",
    "dist:desktop:mac": "npm run dist:mac --workspace=@mcua/desktop --",
    "dist:desktop:win": "npm run dist:win --workspace=@mcua/desktop --",
    "dist:desktop:linux": "npm run dist:linux --workspace=@mcua/desktop --",
    "mobile:update:production": "npm run update:production --workspace=@mcua/mobile",
    "mobile:build:production": "npm run build:all --workspace=@mcua/mobile -- --profile production --non-interactive --no-wait",
    "build:api": "turbo run build --filter=@mcua/api",
    "build:packages": "turbo run build --filter='./packages/*'",
    "build:libs": "turbo run build --filter='./libs/*'",
    "build:services": "turbo run build --filter='./services/*'",
    "publish:desktop:updates": "npm run publish --workspace=@mcua/desktop-update-cdn --",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint -- --fix",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "test:coverage": "turbo run test:coverage",
    "test:ci": "turbo run test -- --reporter=default --reporter=junit",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "clean:turbo": "rm -rf .turbo */.turbo */*/.turbo",
    "db:generate": "turbo run db:generate --filter=@mcua/api",
    "db:migrate": "turbo run db:migrate --filter=@mcua/api",
    "db:seed": "npm run db:seed --workspace=apps/api",
    "db:studio": "npm run db:studio --workspace=apps/api",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:reset": "docker compose down -v && docker compose up -d",
    "check": "npm run lint && npm run type-check && npm run test",
    "ci": "npm run lint && npm run type-check && npm run test && npm run build"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@testing-library/dom": "^10.4.1",
    "@types/node": "^20.0.0",
    "eslint": "^8.57.0",
    "eslint-import-resolver-typescript": "^3.6.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-react": "^7.34.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "dependencies": {
    "ajv": "^8.17.0"
  }
}
